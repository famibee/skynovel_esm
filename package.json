{
	"name": "@famibee/skynovel_esm",
	"version": "2.0.15",
	"description": "webgl novelgame framework",
	"author": "miyazawa famibee",
	"publisher": "famibee",
	"homepage": "http://famibee.blog38.fc2.com/",
	"license": "MIT",
	"main": "./dist/web.js",
