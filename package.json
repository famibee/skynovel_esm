		"adm-zip": "^0.6.0",
		"devtools-detect": "^4.0.2",
		"electron-store": "^11.0.2",
		"fs-extra": "^11.3.6",
		"gamepad.js": "^3.0.1",
		"howler": "^2.2.4",
		"parsimmon": "^1.18.1",
		"pixi.js": "^6.5.10",
		"platform": "^1.3.6",
		"socket.io-client": "^4.8.3",
		"tinygesture": "^3.0.1"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
